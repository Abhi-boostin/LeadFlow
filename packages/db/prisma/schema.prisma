// LeadFlow database schema.
// Source of truth for User, Lead, Discussion, Transcription, NotificationLog.
// Generated client is consumed by apps/api and apps/web through @leadflow/db.

generator client {
  provider = "prisma-client-js"
  // Output the client into our own source tree (Prisma's official monorepo pattern).
  // Consumers import from `@leadflow/db` which re-exports './generated'. This avoids
  // the @prisma/client shim's pnpm-hoisting issues — under pnpm workspaces the shim
  // can't locate .prisma/client/default reliably on Linux CI machines.
  // https://www.prisma.io/docs/orm/prisma-client/setup-and-configuration/generating-prisma-client#using-a-custom-output-path
  output   = "../src/generated"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries via Supabase Transaction pooler (port 6543, pgbouncer).
  url       = env("DATABASE_URL")
  // Migrations require a direct (non-pooled) connection (port 5432) because
  // PgBouncer in transaction mode does not support Prisma's migration queries.
  // Locally `DIRECT_URL` can be unset (falls back to `DATABASE_URL`).
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
}

enum DiscussionSource {
  MANUAL
  TRANSCRIPTION
  SMS_REPLY
  TELEGRAM
}

model User {
  id                    String    @id @default(uuid()) @db.Uuid
  email                 String    @unique
  name                  String
  avatarUrl             String?
  googleId              String?   @unique
  summarizationPrompt   String    @default("Summarise the discussion in 3 bullets. Extract any dates, money amounts, and action items.")
  smsNumber             String?
  smsOptIn              Boolean   @default(false)
  timezone              String    @default("UTC")
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  leads       Lead[]
  discussions Discussion[]

  @@index([email])
}

model Lead {
  id               String     @id @default(uuid()) @db.Uuid
  userId           String     @db.Uuid
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  company          String?
  phone            String?
  status           LeadStatus @default(NEW)
  // Denormalised from latest discussion so filtering by "due today" is a cheap index scan.
  nextFollowUpAt   DateTime?
  // Denormalised so the lead list sorts by recent activity without a join.
  lastDiscussionAt DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  discussions Discussion[]

  @@index([userId, status])
  @@index([userId, nextFollowUpAt])
  @@index([userId, lastDiscussionAt(sort: Desc)])
}

model Discussion {
  id         String           @id @default(uuid()) @db.Uuid
  leadId     String           @db.Uuid
  lead       Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId     String           @db.Uuid
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       String           @db.Text
  followUpAt DateTime?
  source     DiscussionSource @default(MANUAL)
  // Free-form JSON: { summary, rawTranscript, model, promptUsed } and any future AI metadata.
  aiMetadata Json?
  createdAt  DateTime         @default(now())

  transcription Transcription?

  @@index([leadId, createdAt(sort: Desc)])
  @@index([userId, followUpAt])
}

model Transcription {
  id              String     @id @default(uuid()) @db.Uuid
  discussionId    String     @unique @db.Uuid
  discussion      Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  // null until we wire up object storage (Supabase / R2). Whisper transcript is preserved
  // separately in `rawTranscript`, so the audio file itself is optional.
  audioUrl        String?
  rawTranscript   String     @db.Text
  summary         String     @db.Text
  // Snapshot of the user's summarisation prompt at the moment this summary was generated.
  promptUsed      String     @db.Text
  model           String
  durationSeconds Int        @default(0)
  createdAt       DateTime   @default(now())
}

model NotificationLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  // "daily_digest" | "follow_up_reminder" | "weekly_email"
  kind         String
  targetLeadId String?  @db.Uuid
  // "sms" | "email"
  channel      String
  sentAt       DateTime @default(now())

  @@index([userId, kind, sentAt])
}
