# =============================================================================
# LeadFlow — environment variables
# =============================================================================
# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.
#
# Each variable below is tagged with the tier(s) that read it:
#   [API]   = Fastify backend on Render          (apps/api)
#   [WEB]   = Next.js frontend on Vercel         (apps/web)
#   [LOCAL] = needed only for `pnpm dev` against local Docker Postgres
#
# Architecture reminder:
#   Browser → Vercel (UI) → Render (Prisma) → Supabase (Postgres)
# Vercel never imports a database library. All DB calls go through Render.
# =============================================================================


# =============================================================================
# Database  [API + LOCAL]
# =============================================================================
# DATABASE_URL is the runtime pooler. DIRECT_URL is for migrations.
# Local default points at the Docker Compose Postgres service.
# For Supabase, use the connection strings from Settings → Database.
DATABASE_URL="postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public"
DIRECT_URL="postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public"

# Redis (cache + rate-limiting). Optional, unused at the moment.
REDIS_URL="redis://localhost:6379"


# =============================================================================
# Backend API runtime config  [API]
# =============================================================================
API_PORT=4000
API_HOST="0.0.0.0"
NODE_ENV="development"
# Set CRON_ENABLED=false to skip the in-process SMS digest/reminder schedulers.
CRON_ENABLED="true"


# =============================================================================
# AI — Groq (Whisper transcription + Llama summarisation)  [API]
# =============================================================================
# Free keys at https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_SUMMARY_MODEL="llama-3.3-70b-versatile"
GROQ_TRANSCRIBE_MODEL="whisper-large-v3"


# =============================================================================
# SMS — Fast2SMS  [API] — DISABLED
# =============================================================================
# The SMS notification feature (daily digest + 1-hour-before reminders) is
# parked until there's product demand. Uncomment and set this key to revive it,
# then also uncomment the scheduler block in apps/api/src/jobs/index.ts and the
# fetch in apps/api/src/lib/sms.ts.
# https://www.fast2sms.com/dashboard/dev-api
# FAST2SMS_API_KEY=""


# =============================================================================
# Internal server-to-server token  [API + WEB]
# =============================================================================
# Shared secret used by Vercel's Auth.js signIn callback to call Render's
# POST /api/v1/auth/google-user. Browser never sees this. Must be the same value
# on both Vercel and Render. Generate with: `openssl rand -base64 32`
INTERNAL_API_TOKEN=""


# =============================================================================
# Frontend HTTP wiring  [WEB]
# =============================================================================
# NEXT_PUBLIC_API_URL is read by the browser; API_INTERNAL_URL is read by
# Server Components / Server Actions. Same value for both in most setups.
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_INTERNAL_URL="http://localhost:4000"

# Stub-auth fallback for local dev: paste the demo user's id printed by
# `pnpm seed`. Production uses real Google OAuth and ignores this.
NEXT_PUBLIC_DEV_USER_ID=""


# =============================================================================
# Auth.js v5 — Google OAuth  [WEB]
# =============================================================================
# Generate AUTH_SECRET with: `openssl rand -base64 32`
AUTH_SECRET="change-me-in-production"
# Set to `true` when deploying behind a proxy/CDN (Vercel, Render, Cloudflare).
AUTH_TRUST_HOST="true"
# Canonical public URL of the deployed app. e.g. https://your-app.vercel.app
# Leave at localhost for dev.
AUTH_URL="http://localhost:3000"
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add `<AUTH_URL>/api/auth/callback/google` to the Authorized redirect URIs.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
