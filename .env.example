# Copy this file to .env and fill in the values. .env is gitignored.
# Never commit real secrets.

# ==== Database ====
# Local Docker default. For Supabase, use the "Transaction" connection string from
# Settings -> Database -> Connection string.
DATABASE_URL="postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public"

# ==== Redis (cache + rate limiting, optional in dev) ====
REDIS_URL="redis://localhost:6379"

# ==== Backend API ====
API_PORT=4000
API_HOST="0.0.0.0"
NODE_ENV="development"
# AUTH_SECRET is reserved for the Auth.js v5 integration (not yet wired up).
AUTH_SECRET="change-me-in-production"

# ==== Frontend ====
# NEXT_PUBLIC_API_URL is read by the browser. API_INTERNAL_URL is read by Server Components.
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_INTERNAL_URL="http://localhost:4000"
# Stub auth user id while real Auth.js JWT is not wired up.
# After running `pnpm seed`, paste the demo user's id here.
NEXT_PUBLIC_DEV_USER_ID=""

# ==== AI (Groq: Whisper transcription + Llama summarisation) ====
# Free keys at https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_SUMMARY_MODEL="llama-3.3-70b-versatile"
GROQ_TRANSCRIBE_MODEL="whisper-large-v3"

# ==== SMS (Fast2SMS) ====
# https://www.fast2sms.com/dashboard/dev-api
FAST2SMS_API_KEY=""
# Disable cron jobs entirely (useful when running multiple instances).
CRON_ENABLED="true"
