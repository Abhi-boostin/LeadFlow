# Copy this file to .env and fill in the values.
# .env is gitignored. Never commit real secrets.

# Database (Postgres). Local default points at the docker-compose service.
DATABASE_URL="postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public"

# Redis (cache + rate limiting)
REDIS_URL="redis://localhost:6379"

# Backend API
API_PORT=4000
API_HOST="0.0.0.0"

# Frontend
# NEXT_PUBLIC_API_URL is used by the browser to call the API.
# API_INTERNAL_URL is used by Next.js Server Components (can point at a docker service name in prod).
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_INTERNAL_URL="http://localhost:4000"
# Stub-auth user id used while real auth is not wired up. Run `pnpm seed` and grab the demo
# user's id from the script output, then paste it here.
DEV_USER_ID=""

# Auth.js v5 Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
AUTH_SECRET="change-me-in-production"
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Groq (Whisper transcription + Llama summarisation)
# Free API keys at https://console.groq.com/keys
GROQ_API_KEY=""

# Fast2SMS (SMS notifications)
# https://www.fast2sms.com/dashboard/dev-api
FAST2SMS_API_KEY=""

# Resend (email notifications)
# https://resend.com/api-keys
RESEND_API_KEY=""

# Supabase Storage (for meeting audio uploads)
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_AUDIO_BUCKET="meeting-recordings"

# Sentry (optional in dev)
SENTRY_DSN=""

# Environment
NODE_ENV="development"
